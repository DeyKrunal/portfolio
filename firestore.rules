rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Only these emails may write anything. Keep this list in sync with
    // VITE_ADMIN_EMAILS (client-side gating is UX only; THIS is the real
    // access boundary). Update both when you change who administers the site.
    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email in [
          // Replace with your real email(s) before deploying rules.
          'deykrunal71@gmail.com'
        ];
    }

    function isValidString(value, maxLen) {
      return value is string && value.size() <= maxLen;
    }

    // Publicly readable content, admin-only writes.
    match /experience/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /education/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /certificates/{docId} {
      allow read: if true;
      allow write: if isAdmin() &&
        isValidString(request.resource.data.title, 200) &&
        isValidString(request.resource.data.organization, 200);
    }

    match /achievements/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /skills/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gallery/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonials/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Blog posts: public can only read documents already marked "published".
    // Drafts are only visible to the admin, so they don't leak on refresh.
    match /blogPosts/{docId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow write: if isAdmin() &&
        isValidString(request.resource.data.title, 300) &&
        isValidString(request.resource.data.contentMdx, 200000);
    }

    // Site-wide settings (personal info, social links, SEO defaults).
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Contact form submissions, if you choose to also log them to Firestore
    // instead of / in addition to EmailJS. Anyone can create one (rate-limited
    // client-side, see ContactPage.tsx); only the admin can read or delete them.
    match /contactSubmissions/{docId} {
      allow create: if isValidString(request.resource.data.name, 100) &&
        isValidString(request.resource.data.email, 200) &&
        isValidString(request.resource.data.message, 2000);
      allow read, update, delete: if isAdmin();
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
