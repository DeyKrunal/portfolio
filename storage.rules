rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email in [
          'you@example.com'
        ];
    }

    function isReasonableImage() {
      return request.resource.contentType.matches('image/.*') &&
        request.resource.size < 10 * 1024 * 1024; // 10MB
    }

    function isReasonableDocument() {
      return request.resource.contentType == 'application/pdf' &&
        request.resource.size < 20 * 1024 * 1024; // 20MB (resume, certs as PDF)
    }

    // Public media (gallery, certificate images, resume, project screenshots).
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && (isReasonableImage() || isReasonableDocument());
    }

    // Everything else is private by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
