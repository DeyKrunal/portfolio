# Copy this file to .env for local development.
# In CI/production these are set as GitHub Actions secrets (see
# .github/workflows/deploy.yml) — never commit real values.

# --- Firebase (from Firebase Console > Project Settings > General > Your apps) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Admin access ---
# Comma-separated emails allowed into the Admin Dashboard. This is a UX
# convenience only — the real access boundary is firestore.rules /
# storage.rules, which must list the same email(s) separately.
VITE_ADMIN_EMAILS=you@example.com

# --- EmailJS (from emailjs.com dashboard) ---
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# --- GitHub data sync (used only by scripts/fetch-github-data.mjs, never shipped to the client) ---
GH_USERNAME=DeyKrunal
GH_TOKEN=

# --- Blog sitemap/RSS export (used only by scripts/export-blog-index.mjs, never shipped to the client) ---
# Base64-encoded Firebase service account JSON. See README.md >
# "Exporting blog posts for sitemap/RSS" for how to create one. Optional --
# without it, sitemap/RSS just omit individual blog post entries.
FIREBASE_SERVICE_ACCOUNT_KEY=



